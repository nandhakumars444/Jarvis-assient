<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Top bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/bg_surface"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="J.A.R.V.I.S"
            android:textColor="@color/arc_blue"
            android:textSize="16sp"
            android:letterSpacing="0.25" />

        <ImageButton
            android:id="@+id/btnHealth"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_health"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/arc_blue"
            android:contentDescription="Health" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/arc_blue"
            android:contentDescription="Settings" />
    </LinearLayout>

    <!-- Custom arc reactor canvas view -->
    <com.jarvis.assistant.ui.ArcReactorView
        android:id="@+id/arcReactor"
        android:layout_width="190dp"
        android:layout_height="190dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Wake status row -->
    <LinearLayout
        android:id="@+id/wakeRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/arcReactor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/toggleWake"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true" />

        <TextView
            android:id="@+id/tvWakeStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Say \"Hey Jarvis\""
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    <!-- Waveform -->
    <com.jarvis.assistant.ui.WaveformView
        android:id="@+id/waveform"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginTop="4dp"
        android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@id/wakeRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Chat RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:padding="12dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/waveform"
        app:layout_constraintBottom_toTopOf="@id/inputRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Input row -->
    <LinearLayout
        android:id="@+id/inputRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:gravity="center_vertical"
        android:background="@color/bg_surface"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Type a command..."
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:background="@drawable/input_bg"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:imeOptions="actionSend"
            android:inputType="text"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="SEND"
            android:textSize="11sp"
            app:backgroundTint="@color/arc_blue_dim"
            android:textColor="@color/arc_blue" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
