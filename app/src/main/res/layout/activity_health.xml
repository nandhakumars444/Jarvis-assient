<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Health Score Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HEALTH SCORE"
                    android:textColor="@color/arc_blue"
                    android:textSize="11sp"
                    android:letterSpacing="0.2" />

                <TextView
                    android:id="@+id/tvHealthScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Score: -- / 100"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:layout_marginTop="4dp" />

                <ProgressBar
                    android:id="@+id/pbHealth"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="10dp"
                    android:max="100"
                    android:progressTint="@color/arc_blue"
                    android:progressBackgroundTint="@color/bg_dark" />

                <TextView
                    android:id="@+id/tvHealthTip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text=""
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Hydration Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💧 HYDRATION"
                    android:textColor="@color/arc_blue"
                    android:textSize="11sp"
                    android:letterSpacing="0.2" />

                <TextView
                    android:id="@+id/tvWaterAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 ml / 2500 ml"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:layout_marginTop="4dp" />

                <ProgressBar
                    android:id="@+id/pbWater"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="10dp"
                    android:max="2500"
                    android:progressTint="#00bcd4"
                    android:progressBackgroundTint="@color/bg_dark" />

                <!-- Water log buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="14dp"
                    android:gravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn250ml"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="250ml"
                        android:layout_marginEnd="8dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:textColor="@color/arc_blue" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn500ml"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="500ml"
                        android:layout_marginEnd="8dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:textColor="@color/arc_blue" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn750ml"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="750ml"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:textColor="@color/arc_blue" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCustomMl"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Custom ml"
                        android:inputType="number"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCustomMl"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="LOG"
                        app:backgroundTint="@color/arc_blue_dim"
                        android:textColor="@color/arc_blue" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Steps Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚶 STEPS TODAY"
                    android:textColor="@color/arc_blue"
                    android:textSize="11sp"
                    android:letterSpacing="0.2" />

                <TextView
                    android:id="@+id/tvSteps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 / 8000 steps"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:layout_marginTop="4dp" />

                <ProgressBar
                    android:id="@+id/pbSteps"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="10dp"
                    android:max="8000"
                    android:progressTint="#4caf50"
                    android:progressBackgroundTint="@color/bg_dark" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sleep Goal Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌙 SLEEP"
                    android:textColor="@color/arc_blue"
                    android:textSize="11sp"
                    android:letterSpacing="0.2" />

                <TextView
                    android:id="@+id/tvSleepGoal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sleep goal: 8h"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Voice Summary -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHealthVoice"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🎙 JARVIS, READ MY HEALTH SUMMARY"
            android:textSize="12sp"
            app:backgroundTint="@color/arc_blue_dim"
            android:textColor="@color/arc_blue"
            app:cornerRadius="28dp"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

    </LinearLayout>
</ScrollView>
